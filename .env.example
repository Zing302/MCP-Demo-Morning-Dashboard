# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Weather (OpenWeatherMap free tier)
OPENWEATHER_API_KEY=your_openweather_api_key
WEATHER_LOCATION=New York,US

# Stocks — watchlist (comma separated tickers)
STOCK_WATCHLIST=AAPL,MSFT,NVDA,GOOG

# Calendar — local JSON path 
CALENDAR_DATA_PATH=./data/calendar.json

# Journal — local storage path
JOURNAL_DATA_PATH=./data/journal.json

# Log — activity log path
LOG_DATA_PATH=./data/activity.log
